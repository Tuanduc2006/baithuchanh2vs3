<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F5"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DANH SÁCH MÔN HỌC"
        android:textColor="#1A1A1A"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/inputSubject"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập môn học cần thêm"
        android:textSize="17sp"
        android:padding="14dp"
        android:inputType="text"
        android:background="@android:drawable/edit_text" />

    <LinearLayout
        android:id="@+id/buttonArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/addButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="THÊM"
            android:textSize="16sp" />

        <Button
            android:id="@+id/clearButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="XÓA HẾT"
            android:textSize="16sp"
            android:layout_marginStart="10dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/listTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Các môn học đã nhập"
        android:textColor="#333333"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp" />

    <ListView
        android:id="@+id/subjectListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#D0D0D0"
        android:dividerHeight="1dp" />

</LinearLayout>